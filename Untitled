# App
NODE_ENV=development
APP_URL=http://localhost:3000
APP_SECRET=change-me-32-chars-minimum-secret

# Database (PostgreSQL)
DATABASE_URL=postgresql://postgres:password@localhost:5432/logtics
DB_HOST=localhost
DB_PORT=5432
DB_NAME=logtics
DB_USER=postgres
DB_PASSWORD=password

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=change-me-jwt-secret-32-chars-min
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=change-me-refresh-secret-32-chars
JWT_REFRESH_EXPIRES_IN=30d

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASS=your-app-password
EMAIL_FROM=noreply@logtics.io

# S3-compatible Storage
S3_ENDPOINT=https://s3.amazonaws.com
S3_BUCKET=logtics-files
S3_REGION=us-east-1
S3_ACCESS_KEY=your-access-key
S3_SECRET_KEY=your-secret-key

# Realtime (WebSocket)
WS_PORT=3001

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
