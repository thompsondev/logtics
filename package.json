{
  "name": "logtics",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "tsx --env-file .env.local server.ts",
    "dev:next": "next dev",
    "build": "next build",
    "start": "node server.js",
    "lint": "eslint",
    "format": "prettier --write \"src/**/*.{ts,tsx}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx}\"",
    "typecheck": "tsc --noEmit",
    "db:migration:generate": "ts-node -r tsconfig-paths/register ./node_modules/typeorm/cli migration:generate -d typeorm.config.ts",
    "db:migration:run": "ts-node -r tsconfig-paths/register ./node_modules/typeorm/cli migration:run -d typeorm.config.ts",
    "db:migration:revert": "ts-node -r tsconfig-paths/register ./node_modules/typeorm/cli migration:revert -d typeorm.config.ts",
    "db:seed": "ts-node --project tsconfig.json -r tsconfig-paths/register db/seeds/index.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1032.0",
    "@heroui/react": "^3.0.3",
    "@tanstack/react-query": "^5.99.2",
    "@tanstack/react-query-devtools": "^5.99.2",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.74.1",
    "dotenv": "^17.4.2",
    "framer-motion": "^12.38.0",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.3",
    "next": "16.2.4",
    "nodemailer": "^8.0.5",
    "pg": "^8.20.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "reflect-metadata": "^0.2.2",
    "tsx": "^4.21.0",
    "typeorm": "^0.3.28",
    "uuid": "^13.0.0",
    "ws": "^8.20.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.18.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.3",
    "tailwindcss": "^4",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5"
  }
}
